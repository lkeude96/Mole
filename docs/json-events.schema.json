{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://burrow.example/schema/mole/json-events.schema.json",
  "title": "Mole NDJSON Event (one line)",
  "type": "object",
  "required": ["schema_version", "operation", "event", "timestamp", "seq", "run_id", "data"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "operation": {
      "type": "string",
      "enum": ["clean", "uninstall", "analyze", "status", "optimize", "purge", "installer"]
    },
    "event": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "seq": { "type": "integer", "minimum": 1 },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "data": { "type": "object", "additionalProperties": true }
  },
  "oneOf": [
    {
      "title": "Global operation_start",
      "properties": {
        "event": { "const": "operation_start" },
        "data": {
          "type": "object",
          "required": ["mode", "argv", "dry_run"],
          "additionalProperties": true,
          "properties": {
            "mode": { "type": "string", "enum": ["scan", "apply"] },
            "argv": { "type": "array", "items": { "type": "string" } },
            "dry_run": { "type": "boolean" }
          }
        }
      }
    },
    {
      "title": "Global operation_complete",
      "properties": {
        "event": { "const": "operation_complete" },
        "data": {
          "type": "object",
          "required": ["success"],
          "additionalProperties": true,
          "properties": {
            "success": { "type": "boolean" },
            "canceled": { "type": "boolean" },
            "exit_code": { "type": "integer" },
            "duration_ms": { "type": "integer", "minimum": 0 },
            "counts": { "type": "object", "additionalProperties": true },
            "totals": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },
    {
      "title": "Global warning/error",
      "properties": {
        "event": { "enum": ["warning", "error"] },
        "data": {
          "type": "object",
          "required": ["code", "message"],
          "additionalProperties": true,
          "properties": {
            "code": {
              "type": "string",
              "enum": [
                "permission_denied",
                "in_use",
                "not_found",
                "auth_failed",
                "sip_protected",
                "readonly_filesystem",
                "timeout",
                "canceled",
                "unknown"
              ]
            },
            "message": { "type": "string" },
            "path": { "type": "string" },
            "bundle_id": { "type": "string" },
            "action": { "type": "string" },
            "detail": { "type": "string" }
          }
        }
      }
    },

    { "title": "Clean section_start", "properties": { "operation": { "const": "clean" }, "event": { "const": "section_start" }, "data": { "type": "object", "required": ["name"], "additionalProperties": true, "properties": { "name": { "type": "string" } } } } },
    { "title": "Clean section_complete", "properties": { "operation": { "const": "clean" }, "event": { "const": "section_complete" }, "data": { "type": "object", "required": ["name", "item_count", "total_size_bytes"], "additionalProperties": true, "properties": { "name": { "type": "string" }, "item_count": { "type": "integer", "minimum": 0 }, "total_size_bytes": { "type": "integer", "minimum": 0 } } } } },
    { "title": "Clean item_found", "properties": { "operation": { "const": "clean" }, "event": { "const": "item_found" }, "data": { "type": "object", "required": ["path", "category", "size_bytes"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "category": { "type": "string" }, "size_bytes": { "type": "integer", "minimum": 0 }, "age_days": { "type": "integer", "minimum": 0 }, "source": { "type": "string", "enum": ["user", "system", "external"] }, "protected": { "type": "boolean" } } } } },
    { "title": "Clean item_cleaned", "properties": { "operation": { "const": "clean" }, "event": { "const": "item_cleaned" }, "data": { "type": "object", "required": ["path", "size_bytes"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "size_bytes": { "type": "integer", "minimum": 0 } } } } },
    { "title": "Clean item_skipped", "properties": { "operation": { "const": "clean" }, "event": { "const": "item_skipped" }, "data": { "type": "object", "required": ["path", "reason"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "reason": { "type": "string" } } } } },
    { "title": "Clean item_failed", "properties": { "operation": { "const": "clean" }, "event": { "const": "item_failed" }, "data": { "type": "object", "required": ["path", "reason"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "reason": { "type": "string" }, "message": { "type": "string" } } } } },
    { "title": "Clean summary", "properties": { "operation": { "const": "clean" }, "event": { "const": "summary" }, "data": { "type": "object", "required": ["item_count", "total_size_bytes"], "additionalProperties": true, "properties": { "item_count": { "type": "integer", "minimum": 0 }, "total_size_bytes": { "type": "integer", "minimum": 0 }, "skipped_count": { "type": "integer", "minimum": 0 }, "failed_count": { "type": "integer", "minimum": 0 }, "whitelist_skipped_count": { "type": "integer", "minimum": 0 }, "protected_skipped_count": { "type": "integer", "minimum": 0 }, "missing_skipped_count": { "type": "integer", "minimum": 0 }, "permission_denied_skipped_count": { "type": "integer", "minimum": 0 }, "in_use_skipped_count": { "type": "integer", "minimum": 0 }, "permission_denied_count": { "type": "integer", "minimum": 0 } } } } },

    { "title": "Uninstall app_found", "properties": { "operation": { "const": "uninstall" }, "event": { "const": "app_found" }, "data": { "type": "object", "required": ["name", "bundle_id", "path", "size_bytes"], "additionalProperties": true, "properties": { "name": { "type": "string" }, "bundle_id": { "type": "string" }, "path": { "type": "string" }, "size_bytes": { "type": "integer", "minimum": 0 }, "last_used_epoch": { "type": "integer", "minimum": 0 }, "last_used_label": { "type": "string" } } } } },
    { "title": "Uninstall app_removed", "properties": { "operation": { "const": "uninstall" }, "event": { "const": "app_removed" }, "data": { "type": "object", "required": ["bundle_id", "path"], "additionalProperties": true, "properties": { "bundle_id": { "type": "string" }, "path": { "type": "string" }, "size_bytes": { "type": "integer", "minimum": 0 } } } } },
    { "title": "Uninstall leftover_removed", "properties": { "operation": { "const": "uninstall" }, "event": { "const": "leftover_removed" }, "data": { "type": "object", "required": ["path", "size_bytes"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "size_bytes": { "type": "integer", "minimum": 0 } } } } },
    { "title": "Uninstall leftover_skipped", "properties": { "operation": { "const": "uninstall" }, "event": { "const": "leftover_skipped" }, "data": { "type": "object", "required": ["path", "reason"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "reason": { "type": "string" } } } } },
    { "title": "Uninstall leftover_failed", "properties": { "operation": { "const": "uninstall" }, "event": { "const": "leftover_failed" }, "data": { "type": "object", "required": ["path", "reason"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "reason": { "type": "string" }, "message": { "type": "string" } } } } },
    { "title": "Uninstall summary", "properties": { "operation": { "const": "uninstall" }, "event": { "const": "summary" }, "data": { "type": "object", "required": ["app_count"], "additionalProperties": true, "properties": { "app_count": { "type": "integer", "minimum": 0 } } } } },

    { "title": "Optimize optimization_available", "properties": { "operation": { "const": "optimize" }, "event": { "const": "optimization_available" }, "data": { "type": "object", "required": ["category", "action", "name", "description", "safe"], "additionalProperties": true, "properties": { "category": { "type": "string" }, "action": { "type": "string" }, "name": { "type": "string" }, "description": { "type": "string" }, "safe": { "type": "boolean" } } } } },
    { "title": "Optimize summary", "properties": { "operation": { "const": "optimize" }, "event": { "const": "summary" }, "data": { "type": "object", "required": ["count"], "additionalProperties": true, "properties": { "count": { "type": "integer", "minimum": 0 } } } } },
    { "title": "Optimize optimization_start", "properties": { "operation": { "const": "optimize" }, "event": { "const": "optimization_start" }, "data": { "type": "object", "required": ["action", "name"], "additionalProperties": true, "properties": { "action": { "type": "string" }, "name": { "type": "string" } } } } },
    { "title": "Optimize optimization_complete", "properties": { "operation": { "const": "optimize" }, "event": { "const": "optimization_complete" }, "data": { "type": "object", "required": ["action", "success"], "additionalProperties": true, "properties": { "action": { "type": "string" }, "success": { "type": "boolean" }, "message": { "type": "string" } } } } },

    { "title": "Purge purge_path", "properties": { "operation": { "const": "purge" }, "event": { "const": "purge_path" }, "data": { "type": "object", "required": ["root", "source"], "additionalProperties": true, "properties": { "root": { "type": "string" }, "source": { "type": "string", "enum": ["config", "auto"] } } } } },
    { "title": "Purge artifact_found", "properties": { "operation": { "const": "purge" }, "event": { "const": "artifact_found" }, "data": { "type": "object", "required": ["path", "project_root", "project_name", "artifact_type", "size_bytes", "recently_modified"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "project_root": { "type": "string" }, "project_name": { "type": "string" }, "artifact_type": { "type": "string" }, "size_bytes": { "type": "integer", "minimum": 0 }, "recently_modified": { "type": "boolean" } } } } },
    { "title": "Purge artifact_removed", "properties": { "operation": { "const": "purge" }, "event": { "const": "artifact_removed" }, "data": { "type": "object", "required": ["path", "size_bytes"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "size_bytes": { "type": "integer", "minimum": 0 } } } } },
    { "title": "Purge artifact_skipped", "properties": { "operation": { "const": "purge" }, "event": { "const": "artifact_skipped" }, "data": { "type": "object", "required": ["path", "reason"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "reason": { "type": "string" } } } } },
    { "title": "Purge artifact_failed", "properties": { "operation": { "const": "purge" }, "event": { "const": "artifact_failed" }, "data": { "type": "object", "required": ["path", "reason"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "reason": { "type": "string" }, "message": { "type": "string" } } } } },
    { "title": "Purge summary", "properties": { "operation": { "const": "purge" }, "event": { "const": "summary" }, "data": { "type": "object", "required": ["artifact_count", "total_size_bytes"], "additionalProperties": true, "properties": { "artifact_count": { "type": "integer", "minimum": 0 }, "total_size_bytes": { "type": "integer", "minimum": 0 } } } } },

    { "title": "Installer installer_found", "properties": { "operation": { "const": "installer" }, "event": { "const": "installer_found" }, "data": { "type": "object", "required": ["path", "display_name", "source", "size_bytes"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "display_name": { "type": "string" }, "source": { "type": "string" }, "size_bytes": { "type": "integer", "minimum": 0 } } } } },
    { "title": "Installer installer_removed", "properties": { "operation": { "const": "installer" }, "event": { "const": "installer_removed" }, "data": { "type": "object", "required": ["path", "size_bytes"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "size_bytes": { "type": "integer", "minimum": 0 } } } } },
    { "title": "Installer installer_skipped", "properties": { "operation": { "const": "installer" }, "event": { "const": "installer_skipped" }, "data": { "type": "object", "required": ["path", "reason"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "reason": { "type": "string" } } } } },
    { "title": "Installer installer_failed", "properties": { "operation": { "const": "installer" }, "event": { "const": "installer_failed" }, "data": { "type": "object", "required": ["path", "reason"], "additionalProperties": true, "properties": { "path": { "type": "string" }, "reason": { "type": "string" }, "message": { "type": "string" } } } } },
    { "title": "Installer summary", "properties": { "operation": { "const": "installer" }, "event": { "const": "summary" }, "data": { "type": "object", "required": ["installer_count", "total_size_bytes"], "additionalProperties": true, "properties": { "installer_count": { "type": "integer", "minimum": 0 }, "total_size_bytes": { "type": "integer", "minimum": 0 } } } } },

    { "title": "Analyze analyze_start", "properties": { "operation": { "const": "analyze" }, "event": { "const": "analyze_start" }, "data": { "type": "object", "required": ["target_path"], "additionalProperties": true, "properties": { "target_path": { "type": "string" } } } } },
    { "title": "Analyze analyze_progress", "properties": { "operation": { "const": "analyze" }, "event": { "const": "analyze_progress" }, "data": { "type": "object", "required": ["files_scanned", "dirs_scanned", "bytes_scanned"], "additionalProperties": true, "properties": { "files_scanned": { "type": "integer", "minimum": 0 }, "dirs_scanned": { "type": "integer", "minimum": 0 }, "bytes_scanned": { "type": "integer", "minimum": 0 }, "current_path": { "type": "string" } } } } },
    { "title": "Analyze analyze_entry", "properties": { "operation": { "const": "analyze" }, "event": { "const": "analyze_entry" }, "data": { "type": "object", "required": ["parent_path", "name", "path", "is_dir", "size_bytes"], "additionalProperties": true, "properties": { "parent_path": { "type": "string" }, "name": { "type": "string" }, "path": { "type": "string" }, "is_dir": { "type": "boolean" }, "size_bytes": { "type": "integer", "minimum": 0 } } } } },
    { "title": "Analyze analyze_large_file", "properties": { "operation": { "const": "analyze" }, "event": { "const": "analyze_large_file" }, "data": { "type": "object", "required": ["parent_path", "name", "path", "size_bytes"], "additionalProperties": true, "properties": { "parent_path": { "type": "string" }, "name": { "type": "string" }, "path": { "type": "string" }, "size_bytes": { "type": "integer", "minimum": 0 } } } } },
    { "title": "Analyze analyze_complete", "properties": { "operation": { "const": "analyze" }, "event": { "const": "analyze_complete" }, "data": { "type": "object", "required": ["target_path", "total_size_bytes", "entry_count", "large_file_count"], "additionalProperties": true, "properties": { "target_path": { "type": "string" }, "total_size_bytes": { "type": "integer", "minimum": 0 }, "entry_count": { "type": "integer", "minimum": 0 }, "large_file_count": { "type": "integer", "minimum": 0 } } } } },

    { "title": "Status status_start", "properties": { "operation": { "const": "status" }, "event": { "const": "status_start" }, "data": { "type": "object", "required": ["interval_ms", "host", "platform", "hardware"], "additionalProperties": true, "properties": { "interval_ms": { "type": "integer", "minimum": 1 }, "host": { "type": "string" }, "platform": { "type": "string" }, "hardware": { "type": "object", "additionalProperties": true } } } } },
    { "title": "Status status_snapshot", "properties": { "operation": { "const": "status" }, "event": { "const": "status_snapshot" }, "data": { "type": "object", "required": ["collected_at", "health_score"], "additionalProperties": true, "properties": { "collected_at": { "type": "string", "format": "date-time" }, "health_score": { "type": "integer", "minimum": 0, "maximum": 100 } } } } },
    { "title": "Status status_complete", "properties": { "operation": { "const": "status" }, "event": { "const": "status_complete" }, "data": { "type": "object", "additionalProperties": true } } }
  ]
}
